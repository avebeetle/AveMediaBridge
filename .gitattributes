* text=auto

*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.md text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
third_party/ffmpeg/patches/*.patch text eol=lf whitespace=-trailing-space

*.bat text eol=crlf

# Binary files should not be line-normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
